NODE_ENV=production
PORT=5000
# Neon: use the *pooler* host. Do NOT add channel_binding=require (breaks Prisma on Windows).
# Example: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30
# Use Neon *pooler* host (-pooler in hostname). connection_limit=5 avoids pool timeouts.
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require&connect_timeout=30&connection_limit=5&pool_timeout=30&pgbouncer=true
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=30
CLIENT_URL=http://localhost:3000

# Email (Nodemailer) — required for forgot-password emails in production
# Gmail example: enable 2FA and use an App Password for SMTP_PASS

# AgriAI upstream (local: uvicorn on port 8000 — routes are at root, no /api suffix)
AGRIAI_BASE_URL=http://127.0.0.1:8000
AGRIAI_TIMEOUT_MS=30000
