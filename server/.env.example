NODE_ENV=production
PORT=5000
DATABASE_URL=postgresql://user:password@host:5432/dbname
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=30
CLIENT_URL=https://your-frontend-domain.vercel.app

# AgriAI upstream (FastAPI service URL, must include /api suffix)
AGRIAI_BASE_URL=https://your-agriai-service.example.com/api
AGRIAI_TIMEOUT_MS=12000
