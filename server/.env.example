NODE_ENV=production
PORT=5000
# Neon: use the *pooler* host. Do NOT add channel_binding=require (breaks Prisma on Windows).
# Example: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require&connect_timeout=30
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=30
CLIENT_URL=https://your-frontend-domain.vercel.app

# AgriAI upstream (local: uvicorn on port 8001 — routes are at root, no /api suffix)
AGRIAI_BASE_URL=http://127.0.0.1:8001
AGRIAI_TIMEOUT_MS=30000
