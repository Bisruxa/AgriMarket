generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  TRADER
  FARMER
  ADMIN
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProductUnit {
  KG
  LB
  PIECE
  DOZEN
  BUNCH
  BAG
  CRATE
}

enum ProductCategory {
  VEGETABLES
  FRUITS
  GRAINS
  DAIRY
  POULTRY
  MEAT
  SEEDS
  FERTILIZERS
  EQUIPMENT
  OTHER
}

model User {
  id              String          @id @default(cuid())
  name            String
  email           String          @unique
  password        String
  role            UserRole        @default(TRADER)
  phone           String?
  avatar          String?
  isVerified      Boolean         @default(false)
  
  // Trader approval status (only applicable for TRADER role)
  approvalStatus  ApprovalStatus  @default(PENDING)
  approvalNote    String?         // Admin can add a note when approving/rejecting
  
  // Address fields
  street      String?
  city        String?
  state       String?
  country     String?
  zipCode     String?
  
  // Location fields (Ethiopia specific)
  region      String?
  woreda      String?
  
  // Farmer specific fields
  farmSize    String?
  crops       String?
  experience  String?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?  // Soft delete - null means active, timestamp means deleted
  
  // Relations
  products    Product[]
  farms       Farm[]      // One farmer can have multiple farm lands
  
  @@map("users")
}

model Product {
  id            String          @id @default(cuid())
  name          String
  description   String
  price         Decimal         @db.Decimal(10, 2)
  unit          ProductUnit     @default(KG)
  category      ProductCategory
  stock         Int             @default(0)
  images        String[]
  location      String
  isOrganic     Boolean         @default(false)
  harvestDate   DateTime?
  expiryDate    DateTime?
  isAvailable   Boolean         @default(true)
  
  // Ratings
  ratingsAverage Float          @default(0)
  ratingsCount   Int            @default(0)
  
  // Relations
  farmer        User            @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  farmerId      String
  
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  
  @@index([farmerId])
  @@index([category])
  @@index([isAvailable])
  @@map("products")
}

model Farm {
  id            String    @id @default(cuid())
  name          String    // Custom name for the farm land (e.g., "North Field", "Riverside Plot")
  description   String?
  size          String?   // Size of the farm land (e.g., "5 hectares", "2 acres")
  sizeUnit      String?   // Unit of measurement (hectares, acres, etc.)
  
  // Location fields
  region        String?
  woreda        String?
  kebele        String?
  latitude      Float?
  longitude     Float?
  
  // Farm details
  soilType      String?
  waterSource   String?   // e.g., "Rain-fed", "Irrigation", "Well"
  crops         String[]  // Array of crops grown on this farm
  
  isActive      Boolean   @default(true)
  
  // Relations
  farmer        User      @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  farmerId      String
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([farmerId])
  @@map("farms")
}
